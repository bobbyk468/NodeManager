# NodeGrade — Docker Compose environment template
# Copy this file and fill in your secrets:
#   cp .env.docker .env.docker.local
# Then start the stack:
#   docker compose --env-file .env.docker.local up --build
#
# DO NOT commit .env.docker.local — it contains real secrets.

# ── Required ─────────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# PostgreSQL password used by the postgres container and backend DATABASE_URL
POSTGRES_PASSWORD=nodegrade
