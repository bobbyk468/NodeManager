{
  "name": "backend",
  "version": "0.0.1",
  "description": "Reworked backend for NodeGrade",
  "author": "David Fischer",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "env -u NODE_OPTIONS nest start",
    "start:dev": "env -u NODE_OPTIONS nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "node scripts/integration-test.cjs",
    "verify:visualization": "python3 scripts/verify_visualization_api.py",
    "check:dashboard-test-env": "python3 scripts/dashboard_test_prerequisites.py",
    "test:dashboard": "python3 scripts/dashboard_test_prerequisites.py && python3 scripts/verify_visualization_api.py",
    "test:dashboard:full": "python3 scripts/dashboard_test_prerequisites.py --frontend http://localhost:5173 && python3 scripts/verify_visualization_api.py",
    "test:dashboard:wait": "python3 scripts/dashboard_test_prerequisites.py --wait 120 --frontend http://localhost:5173 --run-verify",
    "request:e2e-test": "python3 scripts/request_e2e_pipeline_test.py",
    "request:e2e-test:full": "python3 scripts/request_e2e_pipeline_test.py --frontend http://localhost:5173",
    "test:report": "mkdir -p ../../reports && jest --json --outputFile=../../reports/jest-results.json --testLocationInResults"
  },
  "dependencies": {
    "@haski/lti": "workspace:*",
    "@haski/ta-lib": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.12",
    "@nestjs/websockets": "^11.0.12",
    "@prisma/client": "6.5.0",
    "@xapi/xapi": "^3.0.1",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "6.5.0",
    "socket.io-client": "4.7.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
